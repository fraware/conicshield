# Copy to `.env` locally (never commit `.env`). See README and docs/MAINTAINER_RUNBOOK.md.
# GemFury token for Moreau wheels (pip --extra-index-url).
GEMFURY_TOKEN=your_gemfury_token_here

# Full pip index URL form (optional convenience).
MOREAU_PIP_EXTRA_INDEX_URL=https://your_gemfury_token_here:@pypi.fury.io/optimalintellect/

# Moreau license string; runtime also reads %USERPROFILE%\.moreau\key on Windows or ~/.moreau/key.
MOREAU_LICENSE_KEY=your_moreau_license_key_here
