{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conicshield.dev/schemas/summary.schema.json",
  "title": "ConicShield Benchmark Summary",
  "type": "array",
  "minItems": 1,
  "items": {
    "$ref": "#/$defs/summaryRecord"
  },
  "$defs": {
    "summaryRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "episodes",
        "avg_reward",
        "avg_steps",
        "avg_interventions_per_episode",
        "intervention_rate",
        "rule_violation_rate",
        "matched_action_rate",
        "fallback_rate",
        "solve_time_p50_ms",
        "solve_time_p95_ms",
        "solve_time_p99_ms",
        "setup_time_p50_ms",
        "iterations_p50",
        "avg_intervention_norm",
        "solve_failure_rate",
        "warm_start_rate",
        "device"
      ],
      "properties": {
        "label": {
          "type": "string",
          "enum": [
            "baseline-unshielded",
            "shielded-rules-only",
            "shielded-rules-plus-geometry",
            "shielded-native-moreau"
          ]
        },
        "episodes": {
          "type": "integer",
          "minimum": 1
        },
        "avg_reward": {
          "type": "number"
        },
        "avg_steps": {
          "type": "number",
          "minimum": 0
        },
        "avg_interventions_per_episode": {
          "type": "number",
          "minimum": 0
        },
        "intervention_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rule_violation_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "matched_action_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "fallback_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "solve_time_p50_ms": {
          "type": "number"
        },
        "solve_time_p95_ms": {
          "type": "number"
        },
        "solve_time_p99_ms": {
          "type": "number"
        },
        "setup_time_p50_ms": {
          "type": "number"
        },
        "iterations_p50": {
          "type": "number"
        },
        "avg_intervention_norm": {
          "type": "number",
          "minimum": 0
        },
        "solve_failure_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "warm_start_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reward_retention_vs_baseline": {
          "type": [
            "number",
            "null"
          ]
        },
        "device": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}