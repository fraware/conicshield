{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conicshield.dev/schemas/episodes.schema.json",
  "title": "ConicShield Episodes Schema Container",
  "$defs": {
    "episodeRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "episode_id",
        "arm_label",
        "backend",
        "root_address",
        "rule_choice",
        "bank_id",
        "policy_id",
        "num_steps",
        "total_reward",
        "num_interventions",
        "steps"
      ],
      "properties": {
        "episode_id": {
          "type": "string",
          "minLength": 1
        },
        "arm_label": {
          "type": "string",
          "enum": [
            "baseline-unshielded",
            "shielded-rules-only",
            "shielded-rules-plus-geometry",
            "shielded-native-moreau"
          ]
        },
        "backend": {
          "type": "string",
          "enum": [
            "none",
            "cvxpy_moreau",
            "native_moreau"
          ]
        },
        "root_address": {
          "type": "string",
          "minLength": 1
        },
        "rule_choice": {
          "type": "string",
          "enum": [
            "right",
            "left",
            "alternate"
          ]
        },
        "bank_id": {
          "type": "string",
          "minLength": 1
        },
        "policy_id": {
          "type": "string",
          "minLength": 1
        },
        "policy_checkpoint": {
          "type": [
            "string",
            "null"
          ]
        },
        "seed": {
          "type": [
            "integer",
            "null"
          ]
        },
        "started_at_utc": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "finished_at_utc": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "num_steps": {
          "type": "integer",
          "minimum": 0
        },
        "total_reward": {
          "type": "number"
        },
        "num_interventions": {
          "type": "integer",
          "minimum": 0
        },
        "rule_violations": {
          "type": "integer",
          "minimum": 0
        },
        "matched_action_steps": {
          "type": "integer",
          "minimum": 0
        },
        "fallback_steps": {
          "type": "integer",
          "minimum": 0
        },
        "terminated_reason": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "max_intersections",
            "out_of_bank",
            "no_candidates",
            null
          ]
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stepRecord"
          }
        }
      }
    },
    "stepRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step",
        "current_address",
        "chosen_action",
        "reward",
        "intervened",
        "matched_action",
        "fallback_used"
      ],
      "properties": {
        "step": {
          "type": "integer",
          "minimum": 0
        },
        "current_address": {
          "type": "string",
          "minLength": 1
        },
        "current_location": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        "previous_instruction": {
          "type": [
            "string",
            "null"
          ]
        },
        "available_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "turn_left",
              "turn_right",
              "go_straight",
              "turn_back"
            ]
          },
          "uniqueItems": true
        },
        "chosen_action": {
          "type": "string",
          "enum": [
            "turn_left",
            "turn_right",
            "go_straight",
            "turn_back"
          ]
        },
        "reward": {
          "type": "number"
        },
        "intervened": {
          "type": "boolean"
        },
        "intervention_norm": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "objective_value": {
          "type": [
            "number",
            "null"
          ]
        },
        "raw_q_values": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "number"
          },
          "minItems": 4,
          "maxItems": 4
        },
        "proposed_distribution": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "number"
          },
          "minItems": 4,
          "maxItems": 4
        },
        "corrected_distribution": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "number"
          },
          "minItems": 4,
          "maxItems": 4
        },
        "active_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "matched_action": {
          "type": "boolean"
        },
        "fallback_used": {
          "type": "boolean"
        },
        "selected_action_class": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "turn_left",
            "turn_right",
            "go_straight",
            "turn_back",
            null
          ]
        },
        "selected_destination_address": {
          "type": [
            "string",
            "null"
          ]
        },
        "selected_duration_sec": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "selected_distance_m": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "solver_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "iterations": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "solve_time_sec": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "setup_time_sec": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "construction_time_sec": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "device": {
          "type": [
            "string",
            "null"
          ]
        },
        "warm_started": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}